# The Odds API Configuration
# Get a free API key at https://the-odds-api.com/ (500 requests/month)
#
# Without this key, the app will use demo data and show a warning.
# Set this to enable live odds integration.
#
ODDS_API_KEY=your_api_key_here

# Optional: Streamlit configuration
# Uncomment these to customize the Streamlit server
#
# STREAMLIT_SERVER_PORT=8501
# STREAMLIT_SERVER_HEADLESS=true
